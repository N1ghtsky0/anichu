{{>layout/header}}
{{>layout/navbar}}

<div class="container">
  <div class="row my-2">
    <div class="col-4">
      <img src="/static/images/no_image.jpg" alt="anime_title_thumbnail" style="width: 100%; height: auto"/>
      <p class="text-center">{{score.score}} / 10.0 ({{score.cnt}})</p>
    </div>
    <div class="col-8">
      <table style="width: 100%; height: 100%;">
        <colgroup>
          <col style="width: 10%">
          <col style="width: 90%">
        </colgroup>
        <tr>
          <td colspan="2"><span style="font-size: xxx-large">{{anime.name}}</span></td>
        </tr>
        <tr>
          <th>제작사</th>
          <td>{{anime.companyName}}</td>
        </tr>
        <tr>
          <th>줄거리</th>
          <td>{{anime.summary}}</td>
        </tr>
        <tr>
          <td colspan="2">
            {{#anime.tagList}}
              <span>#{{.}}</span>
            {{/anime.tagList}}
          </td>
        </tr>
      </table>
    </div>
  </div>
  <hr class="my-0"/>
  <div class="comment-box-wrap my-2">
    <ul>
      {{#commentList}}
        <li>
          <div class="comment-box">
            <div class="row justify-content-between">
              <div class="col-8">
                <p>{{content}}</p>
              </div>
              <div class="col-2">
                <p>{{score}}</p>
              </div>
            </div>
          </div>
          <hr/>
        </li>
      {{/commentList}}
      {{^commentList}}
        <li>
          <p>아직 작성된 평가가 없습니다. 첫 평가를 남겨주세요!</p>
        </li>
      {{/commentList}}
    </ul>
  </div>
</div>

{{>layout/footer}}