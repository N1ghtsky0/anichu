{{>layout/header}}
{{>layout/admin_navbar}}

<div class="container-lg" style="min-height: 640px">
  <h1 class="my-4">제작사 관리</h1>
  <table class="table table-striped mb-4">
    <thead>
    <tr>
      <th scope="col">#</th>
      <th scope="col">회사명</th>
    </tr>
    </thead>
    {{#list}}
      <tr>
        <th scope="row">{{seq}}</th>
        <td><a href="/admin/company/{{seq}}">{{name}}</a></td>
      </tr>
    {{/list}}
    {{^list}}
      <tr>
        <td colspan="2">회사 정보가 없습니다.</td>
      </tr>
    {{/list}}
  </table>
  <div class="row justify-content-end">
    <div class="col-1">
      <a class="btn btn-primary w-100" href="/admin/company/new">등록</a>
    </div>
  </div>
</div>

{{>layout/footer}}