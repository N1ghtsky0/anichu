      </div>
      <div class="col-2 mt-auto">
        <div class="row justify-content-evenly arrows">
          <button class="col-4 slick-prev slick-arrow" style="width: auto; height: 40px;">
            <img src="/static/images/arrow_left.svg" alt="slick prev"/>
          </button>
          <button class="col-4 slick-next slick-arrow" style="width: auto; height: 40px;">
            <img src="/static/images/arrow_right.svg" alt="slick next"/>
          </button>
        </div>
      </div>
    </div>
    <div class="mask">
      {{#Top10Quarter.responseDTOList}}
        <div class="mx-2">
          <a href="/anime/{{animeSeq}}">
            <img src="/static/images/no_image.jpg" class="img-fluid img-thumbnail" alt={{animeTitle}}/>
            <p>{{animeTitle}}</p>
            <p>{{score}}/10.0 ({{evaluationCnt}})</p>
            <p>{{companyName}}</p>
          </a>
        </div>
